{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/mounjaro-monitoring/browser",
  "functions": {
    "api/*.ts": {
      "runtime": "nodejs22.x"
    }
  },
  "crons": [
    {
      "path": "/api/notify",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
