{
  "outputDirectory": "dist/mounjaro-monitoring/browser",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/__/auth/(.*)", "destination": "https://mounjaro-monitoring.firebaseapp.com/__/auth/$1" },
    { "source": "/__/firebase/(.*)", "destination": "https://mounjaro-monitoring.firebaseapp.com/__/firebase/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
