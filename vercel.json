{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/mounjaro-monitoring/browser",
  "functions": {
    "api/*.ts": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
