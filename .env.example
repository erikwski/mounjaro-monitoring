# Firebase web app config (from Firebase console → Project settings → Your apps)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Firebase VAPID key (from Firebase console → Cloud Messaging → Web Push certificates)
FIREBASE_VAPID_KEY=

# Firebase Admin service account — base64-encoded JSON
# Generate: base64 -i serviceAccountKey.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Random secret for Vercel Cron authentication
# Generate: openssl rand -hex 32
CRON_SECRET=
